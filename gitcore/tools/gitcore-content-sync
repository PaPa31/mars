#!/bin/sh

set -eu

git rev-parse --show-toplevel >/dev/null

git ls-files | while IFS= read -r path
do
    case "$path" in
        .git/*)
            continue
            ;;
    esac

    if [ -f "$path" ]; then
        printf '===== FILE: %s =====\n' "$path"
        cat "$path"
        printf '\n'
    fi
done
